{
  "name": "flowshot",
  "version": "0.2.0",
  "description": "Flow-based visual regression dashboard for Playwright. One command, one HTML file — screenshots connected as user flows with diff slider.",
  "keywords": [
    "playwright",
    "visual-regression",
    "screenshot",
    "testing",
    "user-flow",
    "dashboard",
    "diff"
  ],
  "license": "MIT",
  "author": "skypart",
  "repository": {
    "type": "git",
    "url": "https://github.com/skypart/flowshot"
  },
  "bin": {
    "flowshot": "bin/flowshot.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean --external playwright",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "release": "./scripts/release.sh",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.58.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
